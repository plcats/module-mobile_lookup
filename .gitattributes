# Auto detect text files and normalize line endings to LF in repository
* text=auto

# Source code
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.ini text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Git config
.gitattributes text eol=lf
.gitignore text eol=lf

# Archives (binary)
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# Images (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Export ignore (files not included in release archives)
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
docs export-ignore
PROJECT_STRUCTURE.md export-ignore
RELEASE.md export-ignore
CONTRIBUTING.md export-ignore
